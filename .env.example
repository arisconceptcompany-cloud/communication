# Base de données (SQLite par défaut — fichier local)
DATABASE_URL="file:./data/intranet.db"

# Secret JWT — générer une clé longue aléatoire en production
AUTH_SECRET="changez-moi-en-production-32-caracteres-min"

# Domaines / emails autorisés (séparés par des virgules)
ALLOWED_EMAIL_DOMAINS="value-it.mg,outsourcia-group.com"

# Boîte à idées — destinataires (séparés par des virgules)
IDEA_BOX_RECIPIENTS="rh@value-it.mg,direction@value-it.mg"

# SMTP pour envoi des emails (boîte à idées, notifications RH)
SMTP_HOST="smtp.votre-serveur.local"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="intranet@value-it.mg"

# URL publique du portail (pour les liens dans les emails)
APP_URL="http://intranet.value-it.local:3000"
INTRANET_HOST="intranet.value-it.local"

# Contabo / VPS (docker-compose.prod.yml + Caddy HTTPS)
DOMAIN="intranet.value-it.mg"

PORT=3000
